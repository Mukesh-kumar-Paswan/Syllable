<% layout("./layouts/boilerplate.ejs") -%>
<div class="container">
    <h2>Quiz Results</h2>
    <div class="score-banner">
        Final Score: <strong><%= score %> / <%= total %></strong>
    </div>

    <div class="results-summary">
        <% results.forEach((res) => { %>
            <div class="result-item <%= res.isCorrect ? 'correct' : 'wrong' %>">
                <p><strong><%= res.title %></strong></p>
                <p>Your Answer: <%= res.userAnswer %></p>
                <% if (!res.isCorrect) { %>
                    <p class="correct-text">Correct Answer: <%= res.correctAnswer %></p>
                <% } %>
            </div>
        <% }) %>
    </div>

    <a href="/syllable" class="back-btn">Try Again</a>
</div>