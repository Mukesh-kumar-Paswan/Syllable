<% layout("./layouts/boilerplate.ejs") -%>

<div class="container">
    <h1>Syllable Quiz</h1>
    <form action="/syllable/attempt" method="POST">
        
        <% allQuestion.forEach((q, index) => { %>
            <div class="question-card">
                <h3><%= index + 1 %>. <%= q.title %></h3>
                <p><%= q.para %></p>
                
                <div class="options">
                    <% q.options.forEach((opt, optIndex) => { %>
                        <label class="option-label">
                            <input type="radio" name="answers[<%= q._id %>]" value="<%= optIndex %>" required>
                            <%= opt %>
                        </label>
                    <% }) %>
                </div>
            </div>
        <% }) %>

        <div class="form-footer">
            <button type="submit" class="submit-all-btn">Submit All Answers</button>
        </div>
    </form>
</div>